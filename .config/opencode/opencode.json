{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "genai"
  ],
  "provider": {
    "genai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "GenAI Gateway",
      "options": {
        "baseURL": "https://genai-gateway.agoda.is/v1",
        "apiKey": "{env:AGODA_GENAI_API_KEY}"
      },
      "models": {
        "gpt-5.2": {
          "name": "gpt-5.2"
        },
        "claude-opus-4-5": {
          "name": "claude-opus-4-5"
        },
        "gemini-3-pro-preview": {
          "name": "gemini-3-pro-preview"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT_&_API_KEY}"
      }
    }
  },
  "instructions": [
    "/Users/wphongphanpa/.config/opencode/rules/*.md"
  ]
}
